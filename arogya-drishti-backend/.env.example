# Environment
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://arogya_user:arogya_secure_password@localhost:5432/arogya_drishti?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-256-bit-secret-in-production-min-32-chars
JWT_REFRESH_SECRET=change-me-to-another-256-bit-secret-for-refresh-tokens
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Encryption (AES-256-GCM for PII fields)
ENCRYPTION_KEY=change-me-to-a-64-hex-char-key-for-aes256-encryption

# Rate Limiting
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=5

# CORS
CORS_ORIGIN=http://localhost:3000
